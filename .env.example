# TrendSignal MVP – Environment Variables
# Másold ezt a fájlt .env-be és töltsd ki a valódi kulcsokat:
#   copy .env.example .env
#
# A .env fájl NEM kerül git-be (.gitignore tartalmazza).
# OS szintű env var mindig felülírja a .env-t (override=False).

# ==========================================
# LLM Context Checker (OpenRouter)
# ==========================================
# Regisztráció: https://openrouter.ai/
# Model: openai/gpt-4o-mini (olcsó, gyors)
OPENROUTER_API_KEY=sk-or-v1-...

# ==========================================
# News API kulcsok (opcionális)
# ==========================================
# GNews – real-time hírgyűjtés
GNEWS_API_KEY=

# Finnhub – pénzügyi hírek (60 req/min free)
FINNHUB_API_KEY=

# Marketaux – pénzügyi hírek (100 req/day free)
MARKETAUX_API_KEY=

# ==========================================
# Telegram Bot (opcionális)
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
